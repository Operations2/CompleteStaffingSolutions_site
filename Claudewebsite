    .card-header p { font-size: 0.85rem; color: var(--gray); }

    .card-body { padding: 1.5rem 1.75rem; }

    .role-list {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem 1rem;
      margin-bottom: 1.5rem;
    }
    .role-list li {
      font-size: 0.82rem;
      color: var(--navy);
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }
    .role-list li::before {
      content: '→';
      color: var(--teal);
      font-size: 0.7rem;
      flex-shrink: 0;
    }

    .card-cta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 1.25rem;
      border-top: 1px solid var(--cream);
    }
    .card-cta-text { font-size: 0.8rem; color: var(--gray); }
    .card-cta-link {
      font-size: 0.82rem;
      font-weight: 600;
