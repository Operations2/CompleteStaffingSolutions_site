  <style>
    :root {
      --navy:   #0A1628;
      --navy2:  #112240;
      --slate:  #1E3A5F;
      --blue:   #1A6BFF;
      --blue-l: #4D8BFF;
      --teal:   #00C4B4;
      --gold:   #E8A020;
      --offwhite: #F7F6F3;
      --cream:  #EEF0F5;
      --gray:   #64748B;
      --light:  #CBD5E1;
      --white:  #FFFFFF;
      --ff-head: 'DM Serif Display', Georgia, serif;
      --ff-body: 'DM Sans', system-ui, sans-serif;
      --r:      0.5rem;
      --r-lg:   1rem;
      --shadow: 0 4px 24px rgba(10,22,40,0.10);
      --shadow-lg: 0 12px 48px rgba(10,22,40,0.15);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: var(--ff-body);
      background: var(--offwhite);
      color: var(--navy);
      line-height: 1.65;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      background: var(--navy);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 16px rgba(0,0,0,0.25);
    }
    .nav-logo {
      font-family: var(--ff-head);
      font-size: 1.2rem;
      color: var(--white);
      text-decoration: none;
      letter-spacing: 0.01em;
    }
    .nav-logo span { color: var(--teal); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--light); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--white); }
    .nav-cta {
      background: var(--teal);
      color: var(--navy) !important;
      padding: 0.45rem 1.25rem;
      border-radius: 100px;
      font-weight: 600 !important;
    }
    .nav-cta:hover { background: #00d6c4 !important; color: var(--navy) !important; }

    /* ── BREADCRUMB ── */
    .breadcrumb {
      background: var(--cream);
      padding: 0.65rem 2rem;
      font-size: 0.8rem;
      color: var(--gray);
      border-bottom: 0.5px solid var(--light);
    }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { margin: 0 0.4rem; }

    /* ── CITY SELECTOR ── */
    .city-bar {
      background: var(--white);
      border-bottom: 1px solid var(--cream);
      padding: 0 2rem;
      overflow-x: auto;
      scrollbar-width: none;
      position: sticky;
      top: 64px;
      z-index: 90;
      box-shadow: 0 2px 8px rgba(10,22,40,0.06);
    }
    .city-bar::-webkit-scrollbar { display: none; }
    .city-tabs {
      display: flex;
      gap: 0;
      min-width: max-content;
    }
    .state-group { display: flex; align-items: stretch; }
    .state-label {
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0 0.75rem;
      display: flex;
      align-items: center;
      border-right: 1px solid var(--cream);
      background: var(--cream);
    }
    .city-tab {
      padding: 0.85rem 1rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--gray);
      cursor: pointer;
      border: none;
      background: transparent;
      border-bottom: 2px solid transparent;
      transition: all 0.18s;
      white-space: nowrap;
    }
    .city-tab:hover { color: var(--blue); background: #f0f5ff; }
    .city-tab.active {
      color: var(--blue);
      border-bottom-color: var(--blue);
      font-weight: 600;
      background: #f0f5ff;
    }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy2) 45%, var(--slate) 100%);
      position: relative;
      overflow: hidden;
      padding: 5rem 2rem 4rem;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40%;
      right: -15%;
      width: 60%;
      height: 200%;
      background: radial-gradient(ellipse, rgba(0,196,180,0.12) 0%, transparent 65%);
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--teal), var(--blue), var(--gold));
    }
    .hero-inner {
      max-width: 900px;
      margin: 0 auto;
      position: relative;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(0,196,180,0.15);
      border: 1px solid rgba(0,196,180,0.3);
      color: var(--teal);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.35rem 0.85rem;
      border-radius: 100px;
      margin-bottom: 1.25rem;
    }
    .hero h1 {
      font-family: var(--ff-head);
      font-size: clamp(2rem, 5vw, 3.25rem);
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 1.25rem;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--teal);
    }
    .hero p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.75);
      max-width: 620px;
      margin-bottom: 2rem;
      line-height: 1.7;
    }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
    .btn-primary {
      background: var(--teal);
      color: var(--navy);
      font-weight: 600;
      font-size: 0.9rem;
      padding: 0.8rem 1.75rem;
      border-radius: 8px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-primary:hover { background: #00d6c4; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,196,180,0.35); }
    .btn-secondary {
      background: transparent;
      color: var(--white);
      font-weight: 500;
      font-size: 0.9rem;
      padding: 0.8rem 1.75rem;
      border-radius: 8px;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.3);
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.5); }
    .hero-stats {
      display: flex;
      gap: 2.5rem;
      flex-wrap: wrap;
    }
    .stat-item { }
    .stat-num {
      font-family: var(--ff-head);
      font-size: 2rem;
      color: var(--white);
      line-height: 1;
    }
    .stat-num span { color: var(--teal); }
    .stat-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; }

    /* ── MAIN CONTENT ── */
    .page-main { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

    /* ── INTRO STRIP ── */
    .intro-strip {
      background: var(--white);
      border-radius: var(--r-lg);
      padding: 2rem 2.5rem;
      margin: 2.5rem 0;
      box-shadow: var(--shadow);
      border-left: 4px solid var(--blue);
    }
    .intro-strip h2 {
      font-family: var(--ff-head);
      font-size: 1.6rem;
      margin-bottom: 0.75rem;
      color: var(--navy);
    }
    .intro-strip p { color: var(--gray); font-size: 1rem; line-height: 1.75; }

    /* ── INDUSTRY SECTIONS ── */
    .industries { margin: 3rem 0; }
    .section-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .section-eyebrow {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 0.5rem;
    }
    .section-header h2 {
      font-family: var(--ff-head);
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      color: var(--navy);
      line-height: 1.25;
    }

    .industry-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }

    .industry-card {
      background: var(--white);
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: transform 0.25s, box-shadow 0.25s;
      border: 1px solid transparent;
    }
    .industry-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
      border-color: var(--blue-l);
    }
    .card-header {
      padding: 1.75rem 1.75rem 1.25rem;
      position: relative;
    }
    .card-header.healthcare { background: linear-gradient(135deg, #E6F7F5 0%, #CCF2ED 100%); }
    .card-header.engineering { background: linear-gradient(135deg, #EEF2FF 0%, #DDE5FF 100%); }
    .card-header.finance { background: linear-gradient(135deg, #FFF8E6 0%, #FFE9B0 100%); }

    .card-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }
    .card-icon.hc { background: var(--teal); }
    .card-icon.en { background: var(--blue); }
    .card-icon.fi { background: var(--gold); }

    .card-header h3 {
      font-family: var(--ff-head);
      font-size: 1.35rem;
      color: var(--navy);
      margin-bottom: 0.35rem;
