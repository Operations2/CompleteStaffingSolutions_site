// SELECT CITY — updates all dynamic content
// ─────────────────────────────────────────────
function selectCity(cityKey, state) {
  const c = cityMap[cityKey];
  if (!c) return;

  // Scroll to top
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // Update tab UI
  document.querySelectorAll('.city-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.city-tab').forEach(t => {
    if (t.getAttribute('onclick') === `selectCity('${cityKey}','${state}')`) {
      t.classList.add('active');
    }
  });

  // SEO meta
  const title = `Staffing Agency in ${c.name}, ${c.state} | Healthcare, Engineering & Finance Recruiting | Complete Staffing Solutions`;
  const desc = `Complete Staffing Solutions is ${c.name}'s trusted staffing agency specializing in Healthcare, Engineering, and Accounting & Finance placements. 25+ years experience. Call (401) 475-8800.`;
  const url = `https://www.completestaffingsolutions.com/staffing-agency-${c.slug}`;

  document.title = title;
  document.getElementById('page-title').textContent = title;
  document.getElementById('meta-desc').setAttribute('content', desc);
  document.getElementById('canonical').setAttribute('href', url);
  document.getElementById('og-title').setAttribute('content', `Staffing Agency in ${c.name}, ${c.state} | Complete Staffing Solutions`);
  document.getElementById('og-desc').setAttribute('content', desc);
  document.getElementById('og-url').setAttribute('content', url);

  // Breadcrumb
  document.getElementById('bc-city').textContent = `Staffing Agency — ${c.name}, ${c.state}`;

  // Hero
  document.getElementById('hero-tag-text').textContent = c.tag;
  document.getElementById('hero-h1-city').textContent = c.name;
  document.getElementById('hero-p-city').textContent = c.name;

  // Intro
  document.getElementById('intro-h2').textContent = c.intro_h2;
  document.getElementById('intro-p').textContent = c.intro_p;

  // Industry card titles
  document.getElementById('hc-title').textContent = `Healthcare Staffing in ${c.name}, ${c.state}`;
  document.getElementById('en-title').textContent = `Engineering Staffing in ${c.name}, ${c.state}`;
  document.getElementById('fi-title').textContent = `Accounting & Finance Staffing in ${c.name}, ${c.state}`;

  // Market section
  document.getElementById('market-h2').textContent = `Why ${c.name} Companies Choose Complete Staffing Solutions`;
  document.getElementById('market-p1').textContent = c.market_p1;
  document.getElementById('market-p2').textContent = c.market_p2;

  // Employer pills
  const pillsEl = document.getElementById('market-pills');
  pillsEl.innerHTML = c.employers.map(e => `<span class="market-pill">${e}</span>`).join('');

  // Nearby cities
  document.getElementById('nearby-h3').textContent = c.nearby_h3;
  const nearbyEl = document.getElementById('nearby-links');
  if (c.nearby.length) {
    nearbyEl.innerHTML = c.nearby.map(([k, s, label]) =>
      `<a class="city-link" onclick="selectCity('${k}','${s}')">${label}</a>`
    ).join('');
  }

  // FAQ
  const faqs = c.faq || [];
  document.querySelectorAll('.faq-item').forEach((item, i) => {
    if (faqs[i]) {
      item.querySelector('.faq-q span').textContent = faqs[i][0];
      item.querySelector('.faq-a').textContent = faqs[i][1];
      item.classList.remove('open');
    }
  });

  // CTA
  document.getElementById('cta-h2').textContent = `Ready to hire in ${c.name}?`;

  // Update schema
  const schema = document.getElementById('schema-org');
  const schemaData = JSON.parse(schema.textContent);
  if (schemaData['@graph'][1]) {
    schemaData['@graph'][1]['@id'] = url;
    schemaData['@graph'][1]['name'] = title;
    schemaData['@graph'][1]['description'] = desc;
    schemaData['@graph'][1].breadcrumb.itemListElement[2].name = `${c.name}, ${c.state}`;
    schemaData['@graph'][1].breadcrumb.itemListElement[2].item = url;
  }
  if (schemaData['@graph'][2] && faqs.length) {
    schemaData['@graph'][2].mainEntity = faqs.map(([q, a]) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a }
    }));
  }
  schema.textContent = JSON.stringify(schemaData, null, 2);
}

